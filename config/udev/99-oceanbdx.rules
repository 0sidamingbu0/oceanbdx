# OceanBDX USB串口设备固定命名规则
# 安装: sudo cp 99-oceanbdx.rules /etc/udev/rules.d/ && sudo udevadm control --reload && sudo udevadm trigger
#
# ★ 必须根据实际硬件修改匹配条件!
# 查看序列号/路径:
#   udevadm info -a -n /dev/ttyUSB0 | grep -E 'serial|devpath|idVendor|idProduct'
#
# 单独设备（已验证）
SUBSYSTEM=="tty", ATTRS{serial}=="5ABA118546", SYMLINK+="ttyeye", MODE="0777", GROUP="ocean"
# IMU
SUBSYSTEM=="tty", ATTRS{manufacturer}=="Yesense Co.Ltd",ATTRS{idProduct}=="5543", SYMLINK+="ttyimu", MODE="0777", GROUP="ocean"
# WCH 四口 USB 串口模块 - 使用环境变量匹配
SUBSYSTEM=="tty", ENV{ID_SERIAL_SHORT}=="0123456789", ENV{ID_USB_INTERFACE_NUM}=="00", SYMLINK+="ttyleft", MODE="0777", GROUP="ocean"
SUBSYSTEM=="tty", ENV{ID_SERIAL_SHORT}=="0123456789", ENV{ID_USB_INTERFACE_NUM}=="02", SYMLINK+="ttybat", MODE="0777", GROUP="ocean"
SUBSYSTEM=="tty", ENV{ID_SERIAL_SHORT}=="0123456789", ENV{ID_USB_INTERFACE_NUM}=="04", SYMLINK+="ttyneck", MODE="0777", GROUP="ocean"
SUBSYSTEM=="tty", ENV{ID_SERIAL_SHORT}=="0123456789", ENV{ID_USB_INTERFACE_NUM}=="06", SYMLINK+="ttyright", MODE="0777", GROUP="ocean"
